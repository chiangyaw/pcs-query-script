# Prisma Cloud credentials
# Copy this file to .env and fill in your values
# Never commit .env to source control

# Your Prisma Cloud Access Key ID
PC_ACCESS_KEY=your_access_key_id_here

# Your Prisma Cloud Secret Key
PC_SECRET_KEY=your_secret_key_here

# Base URL for your Prisma Cloud tenant (region-specific)
# Examples:
#   https://api.prismacloud.io         (US)
#   https://api2.prismacloud.io        (US Gov)
#   https://api.eu.prismacloud.io      (EU)
#   https://api.sg.prismacloud.io      (APAC)
#   https://api.anz.prismacloud.io     (APAC ANZ)
PC_BASE_URL=https://api.prismacloud.io
